{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!**/dist", "!**/node_modules", "!bun.lock"]
	},
	"css": {
		"parser": {
			"cssModules": false,
			"tailwindDirectives": true
		},
		"formatter": {
			"enabled": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": "error",
			"complexity": "error",
			"correctness": "error",
			"nursery": "error",
			"performance": "error",
			"security": "error",
			"style": "error",
			"suspicious": "error"
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**"],
			"linter": {
				"rules": {
					"a11y": {
						"noAutofocus": "off",
						"noLabelWithoutControl": "off",
						"noNoninteractiveElementInteractions": "off",
						"noNoninteractiveElementToInteractiveRole": "off",
						"noRedundantRoles": "off",
						"noStaticElementInteractions": "off",
						"noSvgWithoutTitle": "off",
						"useAriaPropsForRole": "off",
						"useAriaPropsSupportedByRole": "off",
						"useButtonType": "off",
						"useFocusableInteractive": "off",
						"useKeyWithClickEvents": "off",
						"useSemanticElements": "off"
					},
					"complexity": {
						"noExcessiveLinesPerFunction": "off",
						"useMaxParams": "off",
						"noExcessiveCognitiveComplexity": "off",
						"noForEach": "off",
						"noVoid": "off"
					},
					"correctness": {
						"useQwikValidLexicalScope": "off",
						"noProcessGlobal": "off",
						"noInvalidPositionAtImportRule": "off",
						"noNodejsModules": "off",
						"noUndeclaredDependencies": "off",
						"useExhaustiveDependencies": "off",
						"useImageSize": "off",
						"useUniqueElementIds": "off"
					},
					"nursery": {
						"useExplicitType": "off",
						"useExplicitReturnType": "off",
						"noReactNativeRawText": "off",
						"noComponentHookFactories": "off",
						"noConditionalExpect": "off",
						"noDuplicateSelectors": "off",
						"noInlineStyles": "off",
						"noPlaywrightWaitForTimeout": "off",
						"useBaseline": "off",
						"useDomQuerySelector": "off",
						"useExpect": "off",
						"useImportsFirst": "off",
						"useNamedCaptureGroup": "off",
						"useReactFunctionComponentDefinition": "off",
						"useRegexpTest": "off",
						"useTestHooksOnTop": "off",
						"useThisInClassMethods": "off",
						"useUnicodeRegex": "off"
					},
					"performance": {
						"useTopLevelRegex": "off",
						"useSolidForComponent": "off",
						"noImgElement": "off",
						"noJsxPropsBind": "off",
						"noAwaitInLoops": "off",
						"noBarrelFile": "off",
						"noDelete": "off",
						"noNamespaceImport": "off"
					},
					"security": {
						"noDangerouslySetInnerHtml": "off",
						"noSecrets": "off"
					},
					"style": {
						"useNamingConvention": "off",
						"noMagicNumbers": "off",
						"noDefaultExport": "off",
						"noImplicitBoolean": "off",
						"noJsxLiterals": "off",
						"noTernary": "off",
						"noHexColors": "off",
						"useGlobalThis": "off",
						"noContinue": "off",
						"noExcessiveClassesPerFile": "off",
						"noExcessiveLinesPerFile": "off",
						"noExportedImports": "off",
						"noIncrementDecrement": "off",
						"noNestedTernary": "off",
						"noNonNullAssertion": "off",
						"noParameterProperties": "off",
						"noProcessEnv": "off",
						"useAtIndex": "off",
						"useComponentExportOnlyModules": "off",
						"useConsistentArrayType": "off",
						"useConsistentCurlyBraces": "off",
						"useConsistentMemberAccessibility": "off",
						"useConsistentMethodSignatures": "off",
						"useDestructuring": "off",
						"useExportsLast": "off"
					},
					"suspicious": {
						"noReactSpecificProps": "off",
						"noLeakedRender": "off",
						"noAlert": "off",
						"noArrayIndexKey": "off",
						"noConsole": "off",
						"noEmptyBlockStatements": "off",
						"noEqualsToNull": "off",
						"noExplicitAny": "off",
						"noReturnAssign": "off",
						"noShadow": "off",
						"noSkippedTests": "off",
						"noUnnecessaryConditions": "off",
						"useAwait": "off"
					}
				}
			}
		}
	]
}
