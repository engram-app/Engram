#!/usr/bin/env bash
# ./run-tests — single entry point for all Engram test suites
#
# Usage:
#   ./run-tests unit                    # mix test (all)
#   ./run-tests unit test/engram/auth   # mix test <path>
#   ./run-tests browser                 # Playwright local-auth only
#   ./run-tests browser clerk           # Playwright clerk-auth only
#   ./run-tests browser all             # Playwright all projects
#   ./run-tests e2e                     # Python e2e (Obsidian sync)
#   ./run-tests e2e api                 # Python API-only tests
#   ./run-tests db reset                # Drop + recreate + migrate test DB
#   ./run-tests db migrate              # Run pending migrations
#
# Port 5433 — never conflicts with:
#   - CI runners (use -p 0:5432 → random 32768+)
#   - backend-postgres-1 (port 5432)

set -euo pipefail

CONTAINER=engram-e2e-local
PG_PORT=5433
PG_USER=engram
PG_PASS=engram
PG_DB=engram_dev
DATABASE_URL="postgresql://${PG_USER}:${PG_PASS}@localhost:${PG_PORT}/${PG_DB}"
JWT_SECRET="test-local-e2e-secret"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
NC='\033[0m'

log()  { echo -e "${GREEN}▸${NC} $*"; }
warn() { echo -e "${YELLOW}▸${NC} $*"; }
err()  { echo -e "${RED}▸${NC} $*" >&2; }

# ── Postgres lifecycle ──────────────────────────────────────────────

ensure_pg() {
  if docker ps --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
    return 0
  fi

  if docker ps -a --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
    log "Starting stopped ${CONTAINER}..."
    docker start "$CONTAINER" > /dev/null
  else
    log "Creating ${CONTAINER} on port ${PG_PORT}..."
    docker run -d --name "$CONTAINER" \
      --restart unless-stopped \
      -e POSTGRES_USER="$PG_USER" \
      -e POSTGRES_PASSWORD="$PG_PASS" \
      -e POSTGRES_DB="$PG_DB" \
      -p "${PG_PORT}:5432" \
      postgres:18.4 > /dev/null
  fi

  log "Waiting for Postgres..."
  for i in $(seq 1 30); do
    if docker exec "$CONTAINER" pg_isready -U "$PG_USER" > /dev/null 2>&1; then
      log "Postgres ready on port ${PG_PORT}"
      return 0
    fi
    sleep 1
  done
  err "Postgres failed to start"; exit 1
}

ensure_migrated() {
  log "Running migrations..."
  DATABASE_URL="$DATABASE_URL" MIX_ENV=dev mix ecto.migrate --quiet 2>/dev/null || {
    warn "Migration failed — trying ecto.create first..."
    DATABASE_URL="$DATABASE_URL" MIX_ENV=dev mix ecto.create --quiet 2>/dev/null || true
    DATABASE_URL="$DATABASE_URL" MIX_ENV=dev mix ecto.migrate --quiet
  }
}

# ── Test runners ────────────────────────────────────────────────────

run_unit() {
  local path="${1:-}"
  ensure_pg
  log "Running unit tests..."
  if [ -n "$path" ]; then
    DATABASE_URL="$DATABASE_URL" MIX_ENV=test mix test "$path"
  else
    DATABASE_URL="$DATABASE_URL" MIX_ENV=test mix test
  fi
}

run_browser() {
  local project="${1:-local}"
  ensure_pg
  ensure_migrated

  local args=()
  case "$project" in
    local) args=(--project=local) ;;
    clerk) args=(--project=clerk) ;;
    all)   args=() ;;
    *)     args=("$@") ;;
  esac

  log "Running Playwright tests (${project})..."
  cd frontend
  # Playwright starts ALL webServers regardless of --project.
  # Clerk backend needs valid-looking JWKS URL or ClerkStrategy crashes on boot.
  # Placeholder URL lets it start; fetch fails gracefully (retries in background).
  DATABASE_URL="$DATABASE_URL" \
  JWT_SECRET="$JWT_SECRET" \
  AUTH_PROVIDER=local \
  CLERK_JWKS_URL="${CLERK_JWKS_URL:-https://placeholder.clerk.accounts.dev/.well-known/jwks.json}" \
  CLERK_ISSUER="${CLERK_ISSUER:-https://placeholder.clerk.accounts.dev}" \
    bunx playwright test "${args[@]}"
}

run_e2e() {
  local variant="${1:-full}"
  ensure_pg
  ensure_migrated

  case "$variant" in
    api)
      log "Running API-only e2e tests..."
      DATABASE_URL="$DATABASE_URL" \
      JWT_SECRET="$JWT_SECRET" \
      AUTH_PROVIDER=local \
      ENGRAM_API_URL="http://localhost:4000/api" \
        python3 -m pytest e2e/tests/api_only/ -v "${@:2}"
      ;;
    *)
      log "Running full e2e tests..."
      DATABASE_URL="$DATABASE_URL" \
      JWT_SECRET="$JWT_SECRET" \
      AUTH_PROVIDER=local \
      ENGRAM_API_URL="http://localhost:8100/api" \
        python3 -m pytest e2e/tests/ -v "${@:2}"
      ;;
  esac
}

run_db() {
  local cmd="${1:-migrate}"
  ensure_pg
  case "$cmd" in
    reset)
      log "Resetting database..."
      DATABASE_URL="$DATABASE_URL" MIX_ENV=dev mix ecto.reset
      ;;
    migrate)
      ensure_migrated
      ;;
    *)
      err "Unknown db command: $cmd (use: reset, migrate)"
      exit 1
      ;;
  esac
}

# ── Main ────────────────────────────────────────────────────────────

usage() {
  echo -e "${BOLD}Usage:${NC} ./run-tests <suite> [args...]"
  echo ""
  echo "  unit    [path]              mix test"
  echo "  browser [local|clerk|all]   Playwright browser tests"
  echo "  e2e     [api|full]          Python e2e (Obsidian sync)"
  echo "  db      [migrate|reset]     Database management"
  echo ""
  echo "Examples:"
  echo "  ./run-tests unit"
  echo "  ./run-tests unit test/engram/auth"
  echo "  ./run-tests browser"
  echo "  ./run-tests browser clerk"
  echo "  ./run-tests e2e api"
  echo "  ./run-tests db reset"
}

case "${1:-}" in
  unit)    shift; run_unit "$@" ;;
  browser) shift; run_browser "$@" ;;
  e2e)     shift; run_e2e "$@" ;;
  db)      shift; run_db "$@" ;;
  -h|--help|"")  usage ;;
  *)       err "Unknown suite: $1"; usage; exit 1 ;;
esac
